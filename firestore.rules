rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ⚠️ 在此填入有 admin 寫入權限的 Google 帳號 email
    function isAdmin() {
      return request.auth.token.email in [
        "ADMIN_EMAIL_1@example.com",
        "ADMIN_EMAIL_2@example.com"
      ];
    }

    match /tokens/{date} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isAdmin();
    }
    match /punches/{date}/records/{record} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['userId', 'type', 'timestamp', 'token'])
        && request.resource.data.type in ['clock_in', 'clock_out']
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
